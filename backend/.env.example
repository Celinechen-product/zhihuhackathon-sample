ZHIHU_APP_KEY=
ZHIHU_APP_SECRET=
ZHIHU_BASE_URL=https://openapi.zhihu.com/
ZHIHU_SEARCH_URL=https://developer.zhihu.com/api/v1/content/zhihu_search
ZHIHU_ACCESS_SECRET=
ZHIHU_SEARCH_QUERY_PARAM=Query
ZHIHU_SEARCH_COUNT_PARAM=Count

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_QUERY_MODEL=
DEEPSEEK_CLUSTER_MODEL=
DEEPSEEK_JUDGE_MODEL=

# Kimi / Moonshot. Use the base URL matching your API key region.
# For current Moonshot CN API keys, commonly use https://api.moonshot.cn/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_EXTRACT_MODEL=
KIMI_CHAT_MODEL=

# Qwen / Alibaba Bailian
# First test recommendation:
# QWEN_QUERY_MODEL=qwen3.6-flash
# QWEN_EXTRACT_MODEL=qwen3.6-flash
# QWEN_CHAT_MODEL=qwen3.6-flash
# QWEN_CLUSTER_MODEL=qwen3.6-flash
# QWEN_JUDGE_MODEL=qwen3.6-flash
# If extraction quality is insufficient later, try:
# QWEN_EXTRACT_MODEL=qwen3.6-plus
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_QUERY_MODEL=
QWEN_EXTRACT_MODEL=
QWEN_CHAT_MODEL=
QWEN_CLUSTER_MODEL=
QWEN_JUDGE_MODEL=

# Optional OpenAI-compatible fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_FALLBACK_MODEL=

# Router
LLM_DEFAULT_PROVIDER=deepseek
LLM_ENABLE_FALLBACK=true
LLM_REQUEST_TIMEOUT_SECONDS=

# Optional task provider overrides.
# Providers: deepseek, kimi, qwen, openai, legacy.
# Kimi routes are supported, but current kimi-k2.6 may be slow for long
# extraction/persona chat. Use legacy for stable demo, switch to kimi later when
# a faster model/config is verified.
# Qwen routes are supported for follow-up persona/extraction tests.
# Stable demo override recommendation:
# LLM_TASK_EXPERIENCE_EXTRACTION_PROVIDER=legacy
# LLM_TASK_ENTRY_FIELDS_PROVIDER=legacy
# LLM_TASK_PERSONA_CHAT_PROVIDER=legacy
# LLM_TASK_PATH_CLUSTERING_PROVIDER=deepseek
# LLM_TASK_QUERY_UNDERSTANDING_PROVIDER=deepseek
# LLM_TASK_EVAL_JUDGE_PROVIDER=deepseek
LLM_TASK_EXPERIENCE_EXTRACTION_PROVIDER=
LLM_TASK_ENTRY_FIELDS_PROVIDER=
LLM_TASK_PERSONA_CHAT_PROVIDER=
LLM_TASK_PATH_CLUSTERING_PROVIDER=
LLM_TASK_QUERY_UNDERSTANDING_PROVIDER=
LLM_TASK_EVAL_JUDGE_PROVIDER=

# Legacy OpenAI-compatible LLM relay fallback. The backend posts to:
# ${LLM_BASE_URL}/chat/completions
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_CONCURRENCY=3

USE_MOCK_FALLBACK=true
